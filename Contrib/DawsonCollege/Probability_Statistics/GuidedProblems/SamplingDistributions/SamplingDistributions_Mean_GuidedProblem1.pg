# =======================================================
# Build tables RIGHT BEFORE they are displayed
# (prevents answer-blank numbering from getting out of order)
# =======================================================
sub make_tblX {
  return ''
  . '<table border="1" cellpadding="6" cellspacing="0" style="border-collapse:collapse; margin: 0 auto;">'
  . '<tr>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(x\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(P(X=x)\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(x\,P(X=x)\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(x^2\,P(X=x)\)</th>'
  . '</tr>'
  . '<tr>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  . '</tr>'
  . '<tr>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  . '</tr>'
  . '<tr>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  . '</tr>'
  . '<tr>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(6).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  .   '<td align="center">'.ans_rule(8).'</td>'
  . '</tr>'
  . '<tr>'
  .   '<td align="center"><b>Totals</b></td>'
  .   '<td align="center"></td>'
  .   '<td align="center">'.ans_rule(8).'<br/><span style="font-size:90%;">(this total is \(E(X)\))</span></td>'
  .   '<td align="center">'.ans_rule(8).'<br/><span style="font-size:90%;">(this total is \(E(X^2)\))</span></td>'
  . '</tr>'
  . '</table>';
}

sub make_tblXbar {
  return ''
  . '<table border="1" cellpadding="6" cellspacing="0" style="border-collapse:collapse; margin: 0 auto;">'
  . '<tr>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(\bar{x}\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(P(\bar{X}=\bar{x})\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(\bar{x}\,P(\bar{X}=\bar{x})\)</th>'
  .   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\((\bar{x})^2\,P(\bar{X}=\bar{x})\)</th>'
  . '</tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(6).'</td><td align="center">'.ans_rule(8).'</td><td align="center">'.ans_rule(8).'</td></tr>'
  . '<tr>'
  .   '<td align="center"><b>Totals</b></td>'
  .   '<td align="center"></td>'
  .   '<td align="center">'.ans_rule(8).'<br/><span style="font-size:90%;">(this total is \(E(\bar{X})\))</span></td>'
  .   '<td align="center">'.ans_rule(8).'<br/><span style="font-size:90%;">(this total is \(E((\bar{X})^2)\))</span></td>'
  . '</tr>'
  . '</table>';
}

