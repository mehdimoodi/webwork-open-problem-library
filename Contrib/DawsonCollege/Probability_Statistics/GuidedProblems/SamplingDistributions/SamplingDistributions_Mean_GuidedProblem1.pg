$cmp_x_r2_p  = Compute("1/4")->cmp(tolType=>"absolute", tolerance=>$tol);
$cmp_x_r2_c3 = Compute("1/2")->cmp(tolType=>"absolute", tolerance=>$tol);
$cmp_x_r2_c4 = Compute("1")->cmp(tolType=>"absolute", tolerance=>$tol);

