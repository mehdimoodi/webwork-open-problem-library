. '</tr>'
. '<tr>'
.   '<th style="text-align:center; vertical-align:middle; white-space:nowrap;">\(X_1=2\)</th>'
.   '<td align="center">\(1.5\)</td><td align="center">\(2.0\)</td><td align="center">\(2.5\)</td><td align="center">\(3.0\)</td>'
. '</tr>'
. '<tr>'
